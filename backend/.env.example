# Copy to .env and fill in values

# Server
NODE_ENV=development
PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/cefr_platform

# JWT
JWT_SECRET=replace-with-a-long-random-string-in-production

# AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Domain (used for subdomain tenant routing)
BASE_DOMAIN=yourplatform.com

# Audio storage (for speaking exercises)
# AUDIO_BUCKET_URL=https://your-s3-or-storage-bucket
# AUDIO_RETENTION_DAYS=90
